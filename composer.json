{
    "name": "sharmindar/laravel-crm",
    "type": "project",
    "description": "Sharmindar CRM",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^2.0.0",
        "diglactic/laravel-breadcrumbs": "^8.0",
        "doctrine/dbal": "^3.0",
        "enshrined/svg-sanitize": "^0.22.0",
        "guzzlehttp/guzzle": "^7.0.1",
        "khaled.alshamaa/ar-php": "^6.3",
        "konekt/concord": "^1.10",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.2",
        "laravel/tinker": "^2.5",
        "laravel/ui": "^4.5",
        "maatwebsite/excel": "^3.1",
        "mpdf/mpdf": "^8.2",
        "pragmarx/google2fa-laravel": "^2.3",
        "prettus/l5-repository": "^2.7.9",
        "smalot/pdfparser": "^2.11",
        "webklex/laravel-imap": "^5.3"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.6",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.16",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.2",
        "nunomaduro/collision": "^7.0",
        "pestphp/pest": "^2.6",
        "pestphp/pest-plugin-laravel": "^2.1",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Sharmindar\\Core\\Activity\\": "packages/Sharmindar/Core/Activity/src",
            "Sharmindar\\Core\\Admin\\": "packages/Sharmindar/Core/Admin/src",
            "Sharmindar\\Core\\Attribute\\": "packages/Sharmindar/Core/Attribute/src",
            "Sharmindar\\Core\\Automation\\": "packages/Sharmindar/Core/Automation/src",
            "Sharmindar\\Core\\Contact\\": "packages/Sharmindar/Core/Contact/src",
            "Sharmindar\\Core\\DataGrid\\": "packages/Sharmindar/Core/DataGrid/src",
            "Sharmindar\\Core\\DataTransfer\\": "packages/Sharmindar/Core/DataTransfer/src",
            "Sharmindar\\Core\\Email\\": "packages/Sharmindar/Core/Email/src",
            "Sharmindar\\Core\\EmailTemplate\\": "packages/Sharmindar/Core/EmailTemplate/src",
            "Sharmindar\\Core\\Installer\\": "packages/Sharmindar/Core/Installer/src",
            "Sharmindar\\Core\\Lead\\": "packages/Sharmindar/Core/Lead/src",
            "Sharmindar\\Core\\Marketing\\": "packages/Sharmindar/Core/Marketing/src",
            "Sharmindar\\Core\\Product\\": "packages/Sharmindar/Core/Product/src",
            "Sharmindar\\Core\\Quote\\": "packages/Sharmindar/Core/Quote/src",
            "Sharmindar\\Core\\Tag\\": "packages/Sharmindar/Core/Tag/src",
            "Sharmindar\\Core\\User\\": "packages/Sharmindar/Core/User/src",
            "Sharmindar\\Core\\Warehouse\\": "packages/Sharmindar/Core/Warehouse/src",
            "Sharmindar\\Core\\WebForm\\": "packages/Sharmindar/Core/WebForm/src",
            "Sharmindar\\Core\\Department\\": "packages/Sharmindar/Core/Department/src",
            "Sharmindar\\Core\\Settings\\": "packages/Sharmindar/Core/Settings/src",
            "Sharmindar\\Core\\Setting\\": "packages/Sharmindar/Core/Setting/src",
            "Sharmindar\\Core\\Notification\\": "packages/Sharmindar/Core/Notification/src",
            "Sharmindar\\Core\\Dashboard\\": "packages/Sharmindar/Core/Dashboard/src",
            "Sharmindar\\Core\\ITSales\\": "packages/Sharmindar/Core/ITSales/src",
            "Sharmindar\\Core\\": "packages/Sharmindar/Core/src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}